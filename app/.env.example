# 이 파일을 .env로 복사한 뒤 값을 채워 사용하세요. (.env는 git에 커밋하지 않습니다)

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# 프로토타입 단계는 비워두면 SQLite를 사용합니다.
# 클라우드 이전 시 아래 값을 채우고 DB_ENGINE=postgresql로 설정하세요.
# DB_ENGINE=postgresql
# DB_NAME=packaging_mgmt
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# 이메일 발송 우선순위: BREVO_API_KEY > EMAIL_HOST(SMTP) > 모의(로그만).
# 둘 다 비워두면 콘솔/로그로만 남는 모의 발송입니다.

# 1순위 추천: Brevo(HTTPS API) — 방화벽/포트 차단 걱정 없음
# BREVO_API_KEY=

# 2순위: SMTP (사내 메일서버 방화벽에 막힐 수 있음)
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@nousbo.com
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True

# 공통 발신자 표시 주소
# DEFAULT_FROM_EMAIL=noreply@nousbo.com
