# 이 파일을 .env로 복사한 뒤 값을 채워 사용하세요. (.env는 git에 커밋하지 않습니다)

DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# 프로토타입 단계는 비워두면 SQLite를 사용합니다.
# 클라우드 이전 시 아래 값을 채우고 DB_ENGINE=postgresql로 설정하세요.
# DB_ENGINE=postgresql
# DB_NAME=packaging_mgmt
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# 비워두면 이메일은 콘솔/로그로만 남는 모의(mock) 발송입니다.
# 값을 채우면 실제 SMTP로 발송됩니다 (예: nousbo.com 메일 호스팅의 SMTP 정보).
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=noreply@nousbo.com
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@nousbo.com
